{
  "manifest_version": 3,
  "name": "JOSM Strava Heatmap",
  "description": "A browser extension that simplifies getting the TMS imagery url for using the Strava Heatmap in JOSM",
  "version": "6",
  "browser_specific_settings": {
    "gecko": {
      "id": "{7e3ed9ab-2f3c-4263-90a4-b16ec4acc321}"
    }
  },
  "icons": {
    "48": "icons/icon.png"
  },
  "permissions": [
    "cookies"
  ],
  "host_permissions": [
    "*://*.strava.com/*"
  ],
  "content_scripts": [{
    "matches": [
      "*://*.strava.com/heatmap*",
      "*://*.strava.com/maps*"
    ],
    "js": [
      "content.js"
    ],
    "css": [
      "content.css"
    ]
  }],
  "background": {
    "service_worker": "background.js"
  },
  "homepage_url": "https://github.com/zekefarwell/josm-strava-heatmap"
}
